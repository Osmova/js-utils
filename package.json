{
  "name": "@osmova/js-utils",
  "version": "1.5.1",
  "description": "JavaScript/TypeScript utility functions",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./arrays": {
      "types": "./dist/arrays/index.d.ts",
      "import": "./dist/arrays/index.js",
      "require": "./dist/arrays/index.cjs"
    },
    "./async": {
      "types": "./dist/async/index.d.ts",
      "import": "./dist/async/index.js",
      "require": "./dist/async/index.cjs"
    },
    "./browser": {
      "types": "./dist/browser/index.d.ts",
      "import": "./dist/browser/index.js",
      "require": "./dist/browser/index.cjs"
    },
    "./colors": {
      "types": "./dist/colors/index.d.ts",
      "import": "./dist/colors/index.js",
      "require": "./dist/colors/index.cjs"
    },
    "./dates": {
      "types": "./dist/dates/index.d.ts",
      "import": "./dist/dates/index.js",
      "require": "./dist/dates/index.cjs"
    },
    "./functions": {
      "types": "./dist/functions/index.d.ts",
      "import": "./dist/functions/index.js",
      "require": "./dist/functions/index.cjs"
    },
    "./numbers": {
      "types": "./dist/numbers/index.d.ts",
      "import": "./dist/numbers/index.js",
      "require": "./dist/numbers/index.cjs"
    },
    "./objects": {
      "types": "./dist/objects/index.d.ts",
      "import": "./dist/objects/index.js",
      "require": "./dist/objects/index.cjs"
    },
    "./random": {
      "types": "./dist/random/index.d.ts",
      "import": "./dist/random/index.js",
      "require": "./dist/random/index.cjs"
    },
    "./strings": {
      "types": "./dist/strings/index.d.ts",
      "import": "./dist/strings/index.js",
      "require": "./dist/strings/index.cjs"
    },
    "./validation": {
      "types": "./dist/validation/index.d.ts",
      "import": "./dist/validation/index.js",
      "require": "./dist/validation/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Osmova/js-utils.git"
  },
  "author": "Bastien Viglianti <bastien.viglianti@gmail.com>",
  "license": "MIT",
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:node": "node tests/node-test.cjs",
    "test:browser": "node tests/browser-test-runner.cjs",
    "test:all": "pnpm test:node && pnpm test:browser",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix"
  },
  "keywords": [
    "utils",
    "helpers",
    "typescript",
    "javascript"
  ],
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.5.0",
    "puppeteer": "^21.0.0",
    "ts-jest": "^29.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "files": [
    "dist/**/*"
  ]
}
